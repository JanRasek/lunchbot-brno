# Create a Slack Workflow Builder workflow with a "From a webhook" trigger, add a
# "message" text data variable, use it in a "Send a message to a channel" step, publish,
# then paste the generated webhook URL here. (A classic Incoming Webhook works too if you
# have permission to create one, but then post_to_slack() in main.py must send {"text": ...}
# instead of {"message": ...}.)
SLACK_WEBHOOK_URL=https://hooks.slack.com/triggers/XXX/YYY/ZZZ

# Optional
TIMEZONE=Europe/Prague
REQUEST_TIMEOUT_SECONDS=20

# Optional Zomato iframe overrides for Dřevěný Orel/Vlk.
# Vlk is hardcoded with the entity id confirmed from your Vlk DevTools screenshot: 16507597.
# Orel is intentionally NOT hardcoded to that same id, because using the same id makes
# Orel and Vlk return identical menus. Add Orel's real entity id here once confirmed.
# ZOMATO_OREL_ENTITY_ID=16506896
# ZOMATO_VLK_ENTITY_ID=16507597
# or full URL examples:
# ZOMATO_OREL_URL=https://www.zomato.com/widgets/daily_menu.php?entity_id=16506896&width=100%25&height=1000px
# ZOMATO_VLK_URL=https://www.zomato.com/widgets/daily_menu.php?entity_id=16507597&width=100%25&height=1000px
